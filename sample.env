# Copy this file to .env for local runs. On Railway/Render/Heroku/etc, set
# these as dashboard environment variables instead — .env is git-ignored and
# never required in production.

# --- Server ---
PORT=7860
HOST=0.0.0.0
WORKERS=1
ENABLE_DOCS=true

# --- Auth ---
# Comma-separated keys. Leave blank to run fully open (fine for a private
# VPS that only your own bot can reach).
API_KEYS=

# --- yt-dlp / resolution ---
PLAYER_CLIENTS=web_safari,web,android,ios
AGE_BYPASS_CLIENTS=tv_embedded,android
GEO_BYPASS_COUNTRIES=US,GB,DE,CA,IN,NL,JP,SG
URL_CACHE_TTL=10800
SEARCH_CACHE_TTL=600
RESOLVE_TIMEOUT=20
MAX_CONCURRENT_RESOLVES=8

# Optional, off by default — leave unset to stay fully cookieless. If set,
# it must be the *raw contents* of a Netscape-format cookies.txt file (not
# a path), used only as a last-resort resolution tier after every
# cookieless attempt fails. Set this as a Railway/Render dashboard secret,
# never commit it to the repo or .env.
# YT_COOKIES=

# --- Streaming proxy ---
HTTP_CHUNK_SIZE=262144
UPSTREAM_TIMEOUT=300
POOL_MAX_CONNECTIONS=100
POOL_MAX_KEEPALIVE=20

# --- Video (default quality is 720p; raise the ceiling if you want callers
#     to be able to request more via ?height=) ---
VIDEO_DEFAULT_HEIGHT=720
VIDEO_HQ_MAX_HEIGHT=720
VIDEO_SD_MAX_HEIGHT=480
VIDEO_MAX_HEIGHT_CEILING=1080
FFMPEG_PATH=ffmpeg

# --- Rate limiting (0 disables) ---
RATE_LIMIT_PER_MIN=0

CHANNEL_URL=https://t.me/TechTipsCode
