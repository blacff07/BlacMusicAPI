PORT=8000
WORKERS=1

# Leave blank for open API (recommended for private VPS).
# Set comma-separated keys to lock down a public deployment.
API_KEYS=

# Max simultaneous yt-dlp downloads.
# 30 is safe for 50–100 voice chats on a decent VPS (2+ CPU, 2+ GB RAM).
# Raise to 50 on a 4-core machine. Lower to 10 on 1-core.
MAX_CONCURRENT_DOWNLOADS=30

# Seconds to keep downloaded files on disk before auto-delete (default 2h).
CACHE_TTL=7200

# Try without cookies first. Fallback to cookies only on 403/age errors.
COOKIELESS_FIRST=true

# Max video resolution for /vplay (height in pixels).
VIDEO_MAX_HEIGHT=1080

# How long to cache search results in memory (seconds, default 10min).
SEARCH_CACHE_TTL=600

# Set to false to hide the /docs Swagger UI in production.
ENABLE_DOCS=true
